# Console (super admin portal) — server-side environment.
# None of these are NEXT_PUBLIC, so none of them reach the browser.

# Where the proxy at /api/backend forwards to. The browser never talks to
# Django directly, so this does not need to be publicly reachable.
BACKEND_ORIGIN=http://localhost:8000

# Public half of the backend's JWT keypair, used by middleware to verify the
# session cookie's signature before trusting its role claim. Production signs
# with RS256, so set this there. PEM newlines may be written as literal \n.
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"

# Development only. The backend falls back to HS256 signing with SECRET_KEY
# when no keypair is configured; set this to that same value to verify locally.
# JWT_HS_SECRET=

# With neither key set, middleware cannot verify a token. In development it
# degrades to reading the claim unverified and leans on the backend to
# authorise; in production it fails closed and every dashboard route redirects
# to login. Configure a key before deploying.
